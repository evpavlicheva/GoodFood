# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI (dish photo analysis via Claude Vision)
ANTHROPIC_API_KEY=your-key-here
# Optional: override the model used for photo analysis (defaults to claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Push notifications (Web Push / VAPID)
# Generate a pair with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Contact shown to push services, e.g. mailto:you@example.com
VAPID_SUBJECT=mailto:you@example.com

# Shared secret for the reminders cron endpoint (Vercel sends this
# automatically as "Authorization: Bearer $CRON_SECRET" for Cron Jobs).
CRON_SECRET=choose-a-random-secret

# Timezone used to evaluate reminder times (IANA name)
NOTIFICATION_TIMEZONE=Europe/Kyiv
